.env
.env.backup
storage/logs/
storage/framework/cache/
storage/framework/sessions/
storage/framework/views/
bootstrap/cache/
.phpunit.result.cache
.dart_tool/
build/
.flutter-plugins
.flutter-plugins-dependencies
pubspec.lock
.packages
*.log

