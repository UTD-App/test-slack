APP_NAME="Build Your App"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
API_PREFIX=

# Telescope (dev dependency) is off by default: its tables aren't part of the
# base migrations, so leaving it on makes every request fail at terminate on a
# fresh install. To use it: set true, then run `php artisan telescope:install`
# and `php artisan migrate`.
TELESCOPE_ENABLED=false

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=build_your_app
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=pusher
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=file
SESSION_LIFETIME=10080
# 10080 = 7 days. Required for "Remember Me" to work properly.
# Set to false if your server uses HTTP only (no SSL). Set to true for HTTPS servers.
SESSION_SECURE_COOKIE=false
# Leave ASSET_URL empty in local dev so JS/CSS load relative to the current
# host. A fixed host (e.g. http://localhost) breaks Filament/Livewire
# interactivity when you browse a different host (e.g. 127.0.0.1): the assets
# load cross-origin and Alpine/Livewire never boot, so no button or toggle
# fires. Set an absolute URL only behind a CDN/known domain in production.
ASSET_URL=

# Use the pure-PHP predis client (shipped via composer) so Redis works without
# the native phpredis PHP extension. Laravel defaults to 'phpredis' otherwise,
# which fails on machines that don't have the extension installed.
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=

FIREBASE_CREDENTIALS=
FIREBASE_PROJECT_ID=

GOOGLE_CLOUD_STORAGE_BUCKET=
GOOGLE_CLOUD_KEY_FILE=

SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1
