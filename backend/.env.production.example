# Production .env template — copy to .env on the server and fill real values.
# This documents the production-SAFE settings (see deploy/README.md for the
# queue worker + scheduler cron that must also be installed).

APP_NAME="UTD"
APP_ENV=production
APP_KEY=                      # php artisan key:generate
APP_DEBUG=false               # NEVER true in production (leaks stack traces)
APP_URL=https://project-x.utdsoftware.com
API_PREFIX=

# Telescope records every request/query/job — keep OFF in production.
TELESCOPE_ENABLED=false

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning             # debug is far too noisy/large for prod

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# Redis-backed cache/session/queue so they survive across requests/servers and
# so queued jobs actually run (with a supervisor worker — see deploy/README.md).
BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=gcs
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=10080
SESSION_SECURE_COOKIE=true    # HTTPS only in prod

ASSET_URL=

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379

# Sanctum: set a finite token lifetime so leaked tokens expire (minutes).
SANCTUM_EXPIRATION=43200      # 30 days
SANCTUM_STATEFUL_DOMAINS=project-x.utdsoftware.com

# CORS — list only real browser origins; never '*'. Empty = no cross-origin
# browser access (fine for a pure mobile API). Keep credentials off for bearer auth.
CORS_ALLOWED_ORIGINS=
CORS_SUPPORTS_CREDENTIALS=false

# Diagnostic /setup routes — leave EMPTY in prod to disable them.
SETUP_KEY=

# Storage / media
GOOGLE_CLOUD_STORAGE_BUCKET=
GOOGLE_CLOUD_KEY_FILE=        # absolute path on the server, 600 perms, OUTSIDE the repo
STORAGE_PUBLIC_URL=https://project-x.utdsoftware.com/storage

FIREBASE_CREDENTIALS=
FIREBASE_PROJECT_ID=

# Secrets — fill with freshly ROTATED values (the old committed defaults are burned).
DEPLOY_SECRET=
BALANCE_PASSWORD=
UTDSECRTKEY=
ZEGOENCRYPTtkEY=
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
ZEGO_CLIENT_ID=

# UTD Stream Engine (audio-room token endpoint) — secret stays server-side.
UTD_STREAM_APP_ID=
UTD_STREAM_SERVER_SECRET=
UTD_STREAM_ENGINE_URL=https://engine.udt-stream.com

# Optional error aggregation/alerts.
LOG_SLACK_WEBHOOK_URL=
